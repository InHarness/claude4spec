.DS_Store

# docker/environments/*/runtime/ holds generated, per-checkout container
# state (sqlite db, workspace registry, bootstrapped project files) — never
# committed.
docker/environments/*/runtime/
*.log
.env
.env.local
.claude/plans/
.claude/scheduled_tasks.lock
.claude/settings.local.json
pages/

# Prywatne skille (osobne repo: InHarness/claude4spec-private)
.claude/skills/specyfikacja
.claude/skills/pozycjonowanie
.claude/skills/release-process

# Prywatne skrypty (osobne repo: InHarness/claude4spec-private)
scripts/deploy-site.sh
