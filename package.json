{
  "name": "@inharness-ai/claude4spec",
  "version": "1.0.14",
  "description": "Plan the whole system before your agent writes a line of code. Local-first planning layer with structured entities and typed relations.",
  "license": "MIT",
  "author": "Mike Tomala <mike@inharness.ai>",
  "homepage": "https://claude4spec.inharness.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/InHarness/claude4spec.git"
  },
  "bugs": {
    "url": "https://github.com/InHarness/claude4spec/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "specification",
    "spec",
    "markdown",
    "sqlite",
    "ai",
    "agent",
    "local-first"
  ],
  "files": [
    "dist",
    ".claude/skills/c4s-spec-reader",
    ".claude/skills/c4s-brief-implementer",
    "docs/screenshots",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "type": "module",
  "bin": {
    "claude4spec": "dist/bin/claude4spec.js",
    "c4s": "dist/bin/c4s.js",
    "c4s-mcp": "dist/bin/c4s-mcp.js"
  },
  "scripts": {
    "dev": "tsx watch src/bin/claude4spec.ts --mode dev",
    "dev:sandbox": "tsx watch src/bin/claude4spec.ts --mode dev --cwd .claude/skills/specyfikacja --pages .",
    "c4s": "tsx src/bin/c4s.ts",
    "build:server": "tsc -p tsconfig.server.json && rm -rf dist/server/db/migrations && cp -R src/server/db/migrations dist/server/db/migrations && rm -rf dist/server/skills && cp -R src/server/skills dist/server/skills && chmod +x dist/bin/claude4spec.js dist/bin/c4s.js dist/bin/c4s-mcp.js",
    "build:client": "vite build",
    "build": "npm run build:client && npm run build:server",
    "start": "node dist/bin/claude4spec.js",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.client.json --noEmit",
    "deps:link": "node scripts/deps-link.mjs",
    "deps:unlink": "node scripts/deps-unlink.mjs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.109",
    "@google/gemini-cli-core": "^0.42.0",
    "@inharness-ai/agent-adapters": "^0.6.3",
    "@inharness-ai/agent-chat": "^0.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "@openai/codex-sdk": "^0.130.0",
    "@opencode-ai/sdk": "^1.14.48",
    "@tanstack/react-query": "^5.62.11",
    "@tanstack/react-router": "^1.168.23",
    "@tiptap/extension-placeholder": "^2.11.3",
    "@tiptap/extension-table": "^2.27.2",
    "@tiptap/extension-table-cell": "^2.27.2",
    "@tiptap/extension-table-header": "^2.27.2",
    "@tiptap/extension-table-row": "^2.27.2",
    "@tiptap/extension-task-item": "^2.11.3",
    "@tiptap/extension-task-list": "^2.11.3",
    "@tiptap/pm": "^2.11.3",
    "@tiptap/react": "^2.11.3",
    "@tiptap/starter-kit": "^2.11.3",
    "@tiptap/suggestion": "^2.27.2",
    "@types/diff": "^7.0.2",
    "better-sqlite3": "^11.7.0",
    "chokidar": "^4.0.3",
    "diff": "^9.0.0",
    "express": "^4.21.2",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.469.0",
    "mermaid": "^11.14.0",
    "nanoid": "^5.0.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tar": "^7.5.15",
    "tiptap-markdown": "^0.8.10",
    "ws": "^8.18.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@tanstack/router-devtools": "^1.166.13",
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "playwright": "^1.60.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "engines": {
    "node": ">=20"
  }
}
